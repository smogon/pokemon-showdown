{
  "name": "Pokemon Showdown + Foul Play",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {}
  },
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Open Showdown AI",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },
  "postCreateCommand": "bash scripts/codespaces-setup.sh",
  "postStartCommand": "bash scripts/ensure-codespaces-config.sh && bash scripts/showdown-ai.sh start",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
